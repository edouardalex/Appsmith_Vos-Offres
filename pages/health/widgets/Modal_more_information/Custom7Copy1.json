    "css": "@import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap');\n\n:root {\n  --font-primary: 'Poppins', sans-serif;\n  --fw-regular: 500;\n  --fw-medium: 600;\n  --fw-semibold: 700;\n\t\n  --color-text-light: #a6b2bb;\n  --color-text: #596d7b;\n  --color-primary: #82DB35;\n  --color-secondary: #204A83;\n  --color-bg: #ffffff;\n  --color-success: #5CBF86;\n  \n\t--shadow-heavy: -2px -4px 24px rgba(57,67,77,0.12);\n  --radius-sm: 4px;\n  --spacing: 1rem;\n  --spacing-half: 0.5rem;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  font-family: var(--font-primary);\n  background-color: var(--color-bg);\n  color: var(--color-text);\n}\n\n.cta-offer {\n  display: flex;\n  align-items: end;\n  flex-direction: column;\n  gap: var(--spacing);\n  padding: var(--spacing);\n  width: 95%;\n  max-width: 1200px;\n  margin: 0 auto;\n  background: transparent;\n}\n\n.cta-offer__logo {\n  flex: 0 0 auto;\n  width: 30%;\n  border-radius: var(--radius-sm);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  overflow: hidden;\n}\n\n.cta-offer__logo img {\n  width: 100%;\n  height: auto;\n}\n\n.cta-offer__info {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n}\n\n.cta-offer__title {\n  color: var(--color-text);\n  font-size: 1.5rem;\n  font-weight: var(--fw-semibold);\n}\n\n.cta-offer__name {\n  color: var(--color-text-light);\n  font-size: 1rem;\n  font-weight: var(--fw-semibold);\n  margin-top: 0.5rem;\n}\n\n.cta--offer__price_economy {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--spacing-half);\n} \n\n.price-box {\n  background: var(--color-bg);\n  box-shadow: var(--shadow-heavy);\n  border-radius: var(--radius-sm);\n  padding: var(--spacing-half);\n  min-width: 120px;\n  max-width: 180px;\n  width: 100%;\n  box-sizing: border-box;\n  text-align: center;\n}\n\n.offer-price {\n  font-family: var(--font-primary);\n  font-size: 1rem;\n  font-weight: var(--fw-regular);\n  color: var(--color-text);\n  margin: 0;\n}\n\n.offer-price b {\n  font-size: 1.25rem;\n  font-weight: var(--fw-semibold);\n}\n\n.offer-savings {\n  font-family: var(--font-primary);\n  font-size: 1rem;\n  font-weight: var(--fw-regular);\n  margin: 0;\n}\n\n.offer-savings b {\n  font-size: 1.25rem;\n  font-weight: var(--fw-semibold);\n}\n\n.band {\n\tdisplay: grid;\n\tgrid-template-columns: repeat(3, 1fr);\n\tgap: 16px;\n\twidth: 100%;\n\tpadding: 16px;\n}\n\n.band-item {\n\tdisplay: flex;\n\tjustify-content: center;\n\talign-items: center;\n\tpadding: 16px;\n}\n\n.band-item-right {\n\talign-items: end;\n\tjustify-content: flex-end;\n}\n\n.band-item-left {\n\talign-items: start;\n}\n\n@media (max-width: 768px) {\n    .band {\n        grid-template-columns: repeat(2, 1fr);\n        grid-template-rows: auto auto;\n    }\n\n    .band-item:nth-child(3) {\n        grid-column: 1 / -1;\n    }\n}\n\n.cta--offer__actions {\n    display: flex;\n    justify-content: flex-end;\n    flex-direction: row;\n}\n\n.cta--offer__documents {\n\tdisplay: flex;\n}\n\n.btn-cta {\n  display: inline-flex;\n  align-items: center;\n  padding: 0.75em 1em;\n  font-family: var(--font-primary);\n  font-weight: var(--fw-semibold);\n  font-size: 1rem;\n  border: none;\n  border-radius: var(--radius-sm);\n  cursor: pointer;\n  color: white;\n  transition: background-color 0.2s ease;\n}\n\n.btn-cta--primary {\n  background-color: var(--color-primary);\n}\n.btn-cta--primary:hover {\n  background-color: #9BE69E;\n}\n\n.btn-cta--secondary {\n  background-color: var(--color-secondary);\n}\n.btn-cta--secondary:hover {\n  background-color: #163F6B;\n}\n\n.btn-cta-disabled,\n.btn-cta-disabled:hover {\n\tbackground-color: #cccccc;\n\tcolor: #666666;\n\tcursor: not-allowed;\n\topacity: 0.6;\n}\n\n.btn-cta--grey {\n\tcolor: #596D7B;\n  border-radius: 8px;\n\tborder: 1px solid var(--Semantic-Grey-600, #B9C0D2);\n\tbackground: var(--Semantic-Grey-White, #FFF);\n\tdisplay: flex;\n\talign-items: center;\n\tjustify-content: center;\n}\n.btn-cta--grey:hover {\n  background-color: #e5e5e5;\n}\n\n.btn-cta--grey.desactivate {\n\tcolor: #B9C0D2;\n\tbackground: #F5F5F5;\n\tborder-color: #E0E0E0;\n\tcursor: not-allowed;\n\tpointer-events: none;\n}\n\n.btn-cta--grey span {\n\tdisplay: inline-flex;\n\talign-items: center;\n\tjustify-content: center;\n\tmargin-right: 4px;\n}\n\n.btn-cta svg {\n  width: 1em;\n  height: 1em;\n}\n\n@media screen and (max-width: 768px) {\n  .cta-offer {\n\twidth: 100%;\n    flex-direction: column;\n    text-align: center;\n    align-items: center;\n  }\n  .cta-offer__info {\n    align-items: center;\n  }\n  .cta--offer__actions {\n    flex-direction: row;\n    justify-content: center;\n    width: 100%;\n  }\n}\n\n.container-with-scrollbar {\n\toverflow: visible;\n}",
